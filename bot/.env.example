# Catify Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# DO NOT commit the real .env to version control (it is in .gitignore).

# Required: Your Discord bot token from https://discord.com/developers/applications
CATIFY_TOKEN=YOUR_BOT_TOKEN_HERE

# Command prefix (default: !)
CATIFY_PREFIX=!

# Number of obfuscation passes: 1 (default) or 2.
# Pass 2 wraps the entire VM inside a second VM layer — larger but harder to reverse.
CATIFY_PASSES=1

# Maximum inline (in-message) code size in bytes (default: 32768 = 32 KB)
CATIFY_MAX_INLINE=32768

# Maximum file-attachment size in bytes (default: 524288 = 512 KB)
CATIFY_MAX_FILE=524288

# Pastefy API token for `.upload` command (required for uploads)
PASTEFY_API_TOKEN=YOUR_PASTEFY_API_TOKEN_HERE

# Optional Pastefy API endpoint override
PASTEFY_API_URL=https://pastefy.app/api/v2/paste
